    "test": "npm run build && npm run test:compile && npm run test:run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "16.x",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  }
}
