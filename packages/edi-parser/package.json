{
  "name": "edi-parser",
  "version": "0.1.0",
  "description": "Standalone EDI parser package for X12, EDIFACT and VDA.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -p ./ && node scripts/copySchemas.js",
    "test:compile": "tsc -p tsconfig.test.json",
