{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "declaration": true,
    "lib": [
      "ES2020"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/schemas/**/*.json"
  ]
}
