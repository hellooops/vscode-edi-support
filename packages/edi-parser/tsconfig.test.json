{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": false,
    "declaration": false,
    "skipLibCheck": true,
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test/**/*.js"
  ]
}
